{
  "run_name": "owt_baseline",
  "output_dir": "runs/owt_baseline",
  "seed": 1337,
  "device": "auto",
  "precision": "bfloat16",
  "deterministic": false,
  "allow_tf32": true,
  "data": {
    "train": "data/tokenized/owt_train.npy",
    "validation": "data/tokenized/owt_valid.npy"
  },
  "model": {
    "vocab_size": 32000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 1344,
    "rope_theta": 10000.0,
    "remove_rmsnorm": false,
    "use_post_norm": false,
    "remove_rope": false,
    "ffn_type": "swiglu"
  },
  "optimizer": {
    "learning_rate": 0.0003,
    "betas": [0.9, 0.95],
    "eps": 1e-8,
    "weight_decay": 0.1
  },
  "schedule": {
    "min_learning_rate": 0.00003,
    "warmup_iters": 100,
    "cosine_cycle_iters": 10000
  },
  "training": {
    "max_steps": 10000,
    "micro_batch_size": 32,
    "gradient_accumulation_steps": 4,
    "gradient_clip_norm": 1.0
  },
  "evaluation": {
    "interval": 100,
    "batches": 20,
    "batch_size": 32,
    "at_start": true
  },
  "logging": {"interval": 10},
  "checkpoint": {"interval": 500}
}
