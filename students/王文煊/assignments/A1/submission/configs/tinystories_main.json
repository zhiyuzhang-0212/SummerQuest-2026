{
  "train_data": "artifacts/tinystories_train.npy",
  "val_data": "artifacts/tinystories_valid.npy",
  "dtype": "uint16",
  "vocab_size": 10000,
  "context_length": 256,
  "d_model": 512,
  "d_ff": 1344,
  "num_layers": 4,
  "num_heads": 16,
  "rope_theta": 10000.0,
  "norm": "rmsnorm",
  "norm_position": "pre",
  "use_rope": 1,
  "ffn": "swiglu",
  "batch_size": 128,
  "total_steps": 10000,
  "lr": 0.003,
  "min_lr": 0.0003,
  "warmup_steps": 200,
  "weight_decay": 0.1,
  "beta1": 0.9,
  "beta2": 0.95,
  "eps": 1e-8,
  "grad_clip": 1.0,
  "device": "cuda",
  "amp": 1,
  "eval_every": 250,
  "eval_batches": 50,
  "log_every": 20
}
