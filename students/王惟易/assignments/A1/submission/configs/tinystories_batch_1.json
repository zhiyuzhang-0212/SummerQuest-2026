{
  "seed": 42,
  "device": "cuda",
  "data": {
    "train_path": "../data/tinystories_train_uint16.bin",
    "val_path": "../data/tinystories_valid_uint16.bin",
    "dtype": "uint16"
  },
  "model": {
    "vocab_size": 10000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 1344,
    "rope_theta": 10000.0,
    "norm_mode": "pre",
    "position_mode": "rope",
    "ffn_mode": "swiglu"
  },
  "optimizer": {
    "betas": [
      0.9,
      0.95
    ],
    "eps": 1E-8,
    "weight_decay": 0.1
  },
  "training": {
    "batch_size": 1,
    "max_steps": 8192,
    "max_learning_rate": 0.000375,
    "min_learning_rate": 0.0000375,
    "warmup_iters": 1024,
    "cosine_cycle_iters": 8192,
    "max_l2_norm": 1.0,
    "log_interval": 512,
    "eval_interval": 2048,
    "eval_batches": 512,
    "checkpoint_interval": null
  },
  "output": {
    "log_path": "../runs/tinystories_batch_1/metrics.jsonl",
    "checkpoint_path": "../runs/tinystories_batch_1/checkpoint.pt"
  }
}
