{
  "seed": 42,
  "device": "cuda:0",
  "data": {
    "train_path": "../data/owt_train_uint16.bin",
    "val_path": "../data/owt_valid_uint16.bin",
    "dtype": "uint16"
  },
  "model": {
    "vocab_size": 32000,
    "context_length": 256,
    "d_model": 512,
    "num_layers": 4,
    "num_heads": 16,
    "d_ff": 1344,
    "rope_theta": 10000.0,
    "norm_mode": "pre",
    "position_mode": "rope",
    "ffn_mode": "swiglu"
  },
  "optimizer": {
    "betas": [
      0.9,
      0.95
    ],
    "eps": 1e-08,
    "weight_decay": 0.1
  },
  "training": {
    "batch_size": 64,
    "max_steps": 20000,
    "max_learning_rate": 0.003,
    "min_learning_rate": 0.0003,
    "warmup_iters": 500,
    "cosine_cycle_iters": 20000,
    "max_l2_norm": 1.0,
    "log_interval": 10,
    "eval_interval": 250,
    "eval_batches": 20,
    "checkpoint_interval": 1000
  },
  "output": {
    "log_path": "../runs/owt_baseline_full/metrics.jsonl",
    "checkpoint_path": "../runs/owt_baseline_full/checkpoint.pt"
  }
}
