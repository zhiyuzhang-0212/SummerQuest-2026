{
  "data": {
    "train_path": "artifacts/tokenizer_experiments/tinystories_train_uint16.npy",
    "validation_path": "artifacts/tokenizer_experiments/tinystories_dev_uint16.npy"
  },
  "experiment_name": "tinystories_lr_higher_v2",
  "model": {
    "context_length": 256,
    "d_ff": 1344,
    "d_model": 512,
    "ffn_type": "swiglu",
    "norm_mode": "pre",
    "num_heads": 16,
    "num_layers": 4,
    "rope_theta": 10000.0,
    "use_rope": true,
    "vocab_size": 10000
  },
  "optimizer": {
    "betas": [
      0.9,
      0.95
    ],
    "cosine_cycle_steps": 300,
    "eps": 1e-08,
    "max_grad_norm": 1.0,
    "max_learning_rate": 1.0,
    "min_learning_rate": 0.1,
    "warmup_steps": 10,
    "weight_decay": 0.1
  },
  "tokenizer": {
    "eot_token_id": 256,
    "merges_path": "artifacts/tinystories_bpe/merges.json",
    "special_tokens": [
      "<|endoftext|>"
    ],
    "vocab_path": "artifacts/tinystories_bpe/vocab.json"
  },
  "training": {
    "amp_dtype": "bfloat16",
    "batch_size": 128,
    "checkpoint_dir": "artifacts/checkpoints/lr_sweep/tinystories_lr_higher_v2",
    "checkpoint_interval": 0,
    "device": "cuda:0",
    "dtype": "float32",
    "eval_batch_size": 128,
    "eval_batches": 20,
    "eval_interval": 10,
    "gradient_accumulation_steps": 1,
    "log_dir": "logs/lr_sweep/tinystories_lr_higher_v2",
    "log_interval": 10,
    "max_steps": 300,
    "max_wall_clock_sec": null,
    "resume_from": null,
    "seed": 42
  }
}
